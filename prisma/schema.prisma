// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MilestoneDatePrecision {
  DATE
  DATETIME
}

enum LeaveRecordDatePrecision {
  DATE
  DATETIME
}

enum ProjectReceivablePlanStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProjectCostEstimationType {
  planning
  baseline
}

enum ProjectPricingStrategyMode {
  range
  target
}

enum SystemSettingValueType {
  number
  percent
  boolean
  text
  json
}

model Client {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  name             String
  industryOptionId String
  industryOption   SelectOption @relation(fields: [industryOptionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contactLinks    ClientContactClient[]
  projects        Project[]
  receivablePlans ProjectReceivablePlan[]
}

model SelectOption {
  id    String  @id @default(uuid())
  field String
  value String
  color String?
  order Int?

  createdAt DateTime @default(now())

  clientsByIndustry                         Client[]
  vendorsByVendorType                       Vendor[]                         @relation("VendorVendorType")
  vendorsByBusinessType                     Vendor[]                         @relation("VendorBusinessType")
  vendorBusinessTypeOptions                 VendorBusinessTypeOption[]
  vendorsByCooperationStatus                Vendor[]                         @relation("VendorCooperationStatus")
  vendorsByRating                           Vendor[]                         @relation("VendorRating")
  vendorServiceOptions                      VendorServiceOption[]
  employeesByFunction                       Employee[]                       @relation("EmployeeFunction")
  employeesByDepartmentLevel1               Employee[]                       @relation("EmployeeDepartmentLevel1")
  employeesByDepartmentLevel2               Employee[]                       @relation("EmployeeDepartmentLevel2")
  employeesByPosition                       Employee[]                       @relation("EmployeePosition")
  employeesByEmploymentType                 Employee[]                       @relation("EmployeeEmploymentType")
  employeesByEmploymentStatus               Employee[]                       @relation("EmployeeEmploymentStatus")
  leaveRecordsByType                        LeaveRecord[]                    @relation("LeaveRecordType")
  workdayAdjustmentsByChangeType            WorkdayAdjustment[]              @relation("WorkdayAdjustmentChangeType")
  projectsByType                            Project[]                        @relation("ProjectType")
  projectsByStatus                          Project[]                        @relation("ProjectStatus")
  projectsByStage                           Project[]                        @relation("ProjectStage")
  projectSegmentsByStatus                   ProjectSegment[]                 @relation("ProjectSegmentStatus")
  projectTasksByStatus                      ProjectTask[]                    @relation("ProjectTaskStatus")
  projectDocumentsByType                    ProjectDocument[]                @relation("ProjectDocumentType")
  projectMilestonesByType                   ProjectMilestone[]               @relation("ProjectMilestoneType")
  projectMilestonesByMethod                 ProjectMilestone[]               @relation("ProjectMilestoneMethod")
  projectCostEstimationsByExecutionCostType ProjectCostEstimation[]          @relation("ProjectCostEstimationExecutionCostTypes")
  projectPricingStrategyCostTypes           ProjectPricingStrategyCostItem[] @relation("ProjectPricingStrategyCostType")
  projectFinancialStructureExecutionCostTypes ProjectFinancialStructureExecutionCostItem[] @relation("ProjectFinancialStructureExecutionCostType")
  projectReimbursementsByCategory           ProjectReimbursement[]           @relation("ProjectReimbursementCategory")
  plannedWorkEntriesByYear                  PlannedWorkEntry[]               @relation("PlannedWorkEntryYear")
  plannedWorkEntriesByWeekNumber            PlannedWorkEntry[]               @relation("PlannedWorkEntryWeekNumber")
  projectReceivableNodesByStage             ProjectReceivableNode[]          @relation("ProjectReceivableNodeStage")
  projectPayableNodesByStage                ProjectPayableNode[]             @relation("ProjectPayableNodeStage")

  @@unique([field, value])
  @@index([field, order])
}

model SystemSetting {
  id String @id @default(uuid())

  key         String                 @unique
  name        String
  group       String
  value       String
  valueType   SystemSettingValueType @default(number)
  unit        String?
  description String?
  order       Int?
  updatedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([group, order])
}

model ClientContact {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  name       String
  title      String?
  scope      String?
  preference String?

  phone   String?
  email   String?
  wechat  String?
  address String?

  clientLinks ClientContactClient[]

  milestones ProjectMilestone[] @relation("MilestoneClientParticipants")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClientContactClient {
  clientId  String
  contactId String
  order     Int      @default(1000)
  createdAt DateTime @default(now())

  client  Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contact ClientContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([clientId, contactId])
  @@index([clientId, order])
  @@index([contactId])
}

model LegalEntity {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  name      String  @unique
  fullName  String?
  taxNumber String?
  address   String?
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bankAccounts      BankAccount[]
  employees         Employee[]
  clientContracts ClientContract[]
  receivablePlans   ProjectReceivablePlan[]
  vendorContracts   VendorContract[]
}

model BankAccount {
  id String @id @default(uuid())

  legalEntityId String
  legalEntity   LegalEntity @relation(fields: [legalEntityId], references: [id])

  bankName      String
  bankBranch    String
  accountNumber String @unique

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  balanceSnapshots BankAccountBalanceSnapshot[]
  balanceRecords   BankAccountBalanceRecord[]
}

model BankAccountBalanceSnapshot {
  id String @id @default(uuid())

  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  balance    Decimal
  recordedAt DateTime

  notionPageId String? @unique

  createdAt DateTime @default(now())

  @@index([bankAccountId, recordedAt])
}

model BankAccountBalanceRecord {
  id String @id @default(uuid())

  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  balance    Decimal
  snapshotAt DateTime
  remark     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bankAccountId])
  @@index([bankAccountId, snapshotAt])
}

model Employee {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  name     String
  phone    String? @unique
  fullName String?
  password String  @default("admin123")

  functionOptionId String?
  functionOption   SelectOption? @relation("EmployeeFunction", fields: [functionOptionId], references: [id])
  position         String?
  positionOptionId String?
  positionOption   SelectOption? @relation("EmployeePosition", fields: [positionOptionId], references: [id])
  level            String?

  departmentLevel1OptionId String?
  departmentLevel1Option   SelectOption? @relation("EmployeeDepartmentLevel1", fields: [departmentLevel1OptionId], references: [id])
  departmentLevel2OptionId String?
  departmentLevel2Option   SelectOption? @relation("EmployeeDepartmentLevel2", fields: [departmentLevel2OptionId], references: [id])

  employmentTypeOptionId   String?
  employmentTypeOption     SelectOption? @relation("EmployeeEmploymentType", fields: [employmentTypeOptionId], references: [id])
  employmentStatusOptionId String?
  employmentStatusOption   SelectOption? @relation("EmployeeEmploymentStatus", fields: [employmentStatusOptionId], references: [id])

  entryDate DateTime?
  leaveDate DateTime?

  salary          Decimal?
  socialSecurity  Decimal?
  providentFund   Decimal?
  workstationCost Decimal?
  utilityCost     Decimal?

  bankAccountNumber String?
  bankName          String?
  bankBranch        String?

  legalEntityId String?
  legalEntity   LegalEntity? @relation(fields: [legalEntityId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leaveRecords                LeaveRecord[]
  ownedProjects               Project[]                                  @relation("ProjectOwner")
  ownedProjectCostEstimations ProjectCostEstimation[]                    @relation("ProjectCostEstimationOwner")
  projects                    Project[]                                  @relation("ProjectMembers")
  projectSegments             ProjectSegment[]
  ownedTasks                  ProjectTask[]                              @relation("TaskOwner")
  createdTasks                ProjectTask[]                              @relation("TaskCreator")
  milestones                  ProjectMilestone[]                         @relation("MilestoneInternalParticipants")
  projectCostEstimations      ProjectCostEstimationMember[]
  actualWorkEntries           ActualWorkEntry[]
  roles                       EmployeeRole[]
  apiCallLogs                 ApiCallLog[]
  ownedProjectReceivablePlans ProjectReceivablePlan[]                    @relation("ProjectReceivablePlanOwner")
  ownedProjectPayablePlans    ProjectPayablePlan[]                       @relation("ProjectPayablePlanOwner")
  projectReimbursements       ProjectReimbursement[]                     @relation("ProjectReimbursementApplicant")
  receivableExpectedDateEdits ProjectReceivableNodeExpectedDateHistory[]
}

model Role {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees EmployeeRole[]
}

model EmployeeRole {
  employeeId String
  roleId     String
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  role     Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([employeeId, roleId])
  @@index([roleId])
}

model LeaveRecord {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  typeOptionId  String?
  typeOption    SelectOption?            @relation("LeaveRecordType", fields: [typeOptionId], references: [id])
  startAt       DateTime
  endAt         DateTime?
  datePrecision LeaveRecordDatePrecision @default(DATE)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId, startAt])
}

// 工作日变动：管理每年的休假、调休等日期变动
model WorkdayAdjustment {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  name               String? // 名称/描述，如「春节调休」
  changeTypeOptionId String?
  changeTypeOption   SelectOption? @relation("WorkdayAdjustmentChangeType", fields: [changeTypeOptionId], references: [id])
  startDate          DateTime // 开始日期
  endDate            DateTime // 结束日期

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startDate, endDate])
}

model Project {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  // 基础字段
  name           String
  typeOptionId   String?
  typeOption     SelectOption? @relation("ProjectType", fields: [typeOptionId], references: [id])
  statusOptionId String?
  statusOption   SelectOption? @relation("ProjectStatus", fields: [statusOptionId], references: [id])
  stageOptionId  String?
  stageOption    SelectOption? @relation("ProjectStage", fields: [stageOptionId], references: [id])
  isArchived     Boolean       @default(false)

  startDate DateTime?
  endDate   DateTime?

  // relation

  // 所属客户
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  // 项目负责人
  ownerId String?
  owner   Employee? @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  // 项目成员（多对多）
  members Employee[] @relation("ProjectMembers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  segments ProjectSegment[]

  documents         ProjectDocument[]
  vendors           Vendor[]                 @relation("ProjectVendors")
  milestones        ProjectMilestone[]
  costEstimations   ProjectCostEstimation[]
  pricingStrategies ProjectPricingStrategy[]
  financialStructures ProjectFinancialStructure[]
  reimbursements      ProjectReimbursement[]
  clientContracts ClientContract[]
  vendorContracts   VendorContract[]
  actualWorkEntries ActualWorkEntry[]
  receivablePlans   ProjectReceivablePlan[]
  payablePlans      ProjectPayablePlan[]
}

model ClientContract {
  id String @id @default(uuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  legalEntityId String
  legalEntity   LegalEntity @relation(fields: [legalEntityId], references: [id], onDelete: Restrict)

  contractAmount Decimal?
  taxAmount      Decimal?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  receivablePlans ProjectReceivablePlan[]

  @@unique([projectId], map: "CustomerContract_projectId_key")
  @@index([projectId], map: "CustomerContract_projectId_idx")
  @@index([legalEntityId], map: "CustomerContract_legalEntityId_idx")
  @@map("CustomerContract")
}

model VendorContract {
  id String @id @default(uuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Restrict)

  legalEntityId String
  legalEntity   LegalEntity @relation(fields: [legalEntityId], references: [id], onDelete: Restrict)

  serviceContent String?
  contractAmount Int

  payablePlans ProjectPayablePlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([vendorId])
  @@index([legalEntityId])
}

model ProjectReceivablePlan {
  id String @id @default(uuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Restrict)

  clientContractId String? @map("customerContractId")
  clientContract   ClientContract? @relation(fields: [clientContractId], references: [id], onDelete: SetNull)

  legalEntityId String
  legalEntity   LegalEntity @relation(fields: [legalEntityId], references: [id], onDelete: Restrict)

  ownerEmployeeId String
  ownerEmployee   Employee @relation("ProjectReceivablePlanOwner", fields: [ownerEmployeeId], references: [id], onDelete: Restrict)

  contractAmount       Int
  serviceContent       String?
  remark               String?
  remarkNeedsAttention Boolean                     @default(false)
  status               ProjectReceivablePlanStatus @default(DRAFT)

  nodes ProjectReceivableNode[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([clientId])
  @@index([clientContractId], map: "ProjectReceivablePlan_customerContractId_idx")
  @@index([legalEntityId])
  @@index([ownerEmployeeId])
  @@index([projectId, status])
}

model ProjectPayablePlan {
  id String @id @default(uuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  vendorContractId String?
  vendorContract   VendorContract? @relation(fields: [vendorContractId], references: [id], onDelete: SetNull)

  ownerEmployeeId String
  ownerEmployee   Employee @relation("ProjectPayablePlanOwner", fields: [ownerEmployeeId], references: [id], onDelete: Restrict)

  contractAmount       Int
  remark               String?
  remarkNeedsAttention Boolean @default(false)

  nodes ProjectPayableNode[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([vendorContractId])
  @@index([ownerEmployeeId])
}

model ProjectReceivableNode {
  id String @id @default(uuid())

  planId String
  plan   ProjectReceivablePlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  stageOptionId String
  stageOption   SelectOption @relation("ProjectReceivableNodeStage", fields: [stageOptionId], references: [id], onDelete: Restrict)

  sortOrder      Int
  keyDeliverable String

  expectedAmountTaxIncluded Int
  expectedDate              DateTime
  expectedDateChangeCount   Int      @default(0)
  hasVendorPayment          Boolean  @default(false)

  remark               String?
  remarkNeedsAttention Boolean @default(false)

  expectedDateHistories ProjectReceivableNodeExpectedDateHistory[]
  actualNodes           ProjectReceivableActualNode[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([planId, sortOrder])
  @@index([planId])
  @@index([stageOptionId])
  @@index([planId, expectedDate])
}

model ProjectReceivableActualNode {
  id String @id @default(uuid())

  receivableNodeId String
  receivableNode   ProjectReceivableNode @relation(fields: [receivableNodeId], references: [id], onDelete: Cascade)

  actualAmountTaxIncluded Int
  actualDate              DateTime
  remark                  String?
  remarkNeedsAttention    Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([receivableNodeId])
  @@index([receivableNodeId, actualDate])
}

model ProjectPayableNode {
  id String @id @default(uuid())

  planId String
  plan   ProjectPayablePlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  stageOptionId String
  stageOption   SelectOption @relation("ProjectPayableNodeStage", fields: [stageOptionId], references: [id], onDelete: Restrict)

  sortOrder                 Int
  paymentCondition          String
  expectedAmountTaxIncluded Int
  expectedDate              DateTime
  hasCustomerCollection     Boolean  @default(false)
  remark                    String?
  remarkNeedsAttention      Boolean  @default(false)

  actualNodes ProjectPayableActualNode[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([planId, sortOrder])
  @@index([planId])
  @@index([stageOptionId])
  @@index([planId, expectedDate])
}

model ProjectPayableActualNode {
  id String @id @default(uuid())

  payableNodeId String
  payableNode   ProjectPayableNode @relation(fields: [payableNodeId], references: [id], onDelete: Cascade)

  actualAmountTaxIncluded Int
  actualDate              DateTime
  remark                  String?
  remarkNeedsAttention    Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([payableNodeId])
  @@index([payableNodeId, actualDate])
}

model ProjectReceivableNodeExpectedDateHistory {
  id String @id @default(uuid())

  nodeId String
  node   ProjectReceivableNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  fromExpectedDate DateTime
  toExpectedDate   DateTime

  changedByEmployeeId String
  changedByEmployee   Employee @relation(fields: [changedByEmployeeId], references: [id], onDelete: Restrict)

  changedAt DateTime @default(now())
  reason    String?
  remark    String?

  @@index([nodeId])
  @@index([nodeId, changedAt(sort: Desc)])
  @@index([changedByEmployeeId])
}

model ProjectCostEstimation {
  id String @id @default(uuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  ownerId String?
  owner   Employee? @relation("ProjectCostEstimationOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  version Int
  type    ProjectCostEstimationType @default(planning)

  estimatedDuration      Int
  clientBudget        String?
  contractAmountSnapshot Float?

  totalLaborCost           Float   @default(0)
  agencyFeeRate           Float?   @default(0)
  outsourceRemark         String?
  otherExecutionCostRemark String?

  executionCostTypes SelectOption[]               @relation("ProjectCostEstimationExecutionCostTypes")
  members            ProjectCostEstimationMember[]
  outsourceItems     ProjectOutsourceItem[]       @relation("ProjectCostEstimationOutsourceItems")
  pricingStrategies  ProjectPricingStrategy[]
  financialStructures ProjectFinancialStructure[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, version])
  @@index([projectId, type])
  @@index([ownerId])
}

model ProjectCostEstimationMember {
  id String @id @default(uuid())

  estimationId String
  estimation   ProjectCostEstimation @relation(fields: [estimationId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  allocationPercent Int
  laborCostSnapshot Float
  rentCostSnapshot  Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([estimationId, employeeId])
  @@index([estimationId])
  @@index([employeeId])
}

model ProjectPricingStrategy {
  id String @id @default(uuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  estimationId String                @unique
  estimation   ProjectCostEstimation @relation(fields: [estimationId], references: [id], onDelete: Cascade)

  estimatedDuration   Int
  mode                ProjectPricingStrategyMode @default(range)
  rentCost            Float

  plannedLaborCost   Float
  suggestedLaborCost Float

  plannedMiddleOfficeCost   Float
  suggestedMiddleOfficeCost Float

  plannedExecutionCost Float
  agencyFeeRate        Float?
  outsourceRemark      String?

  bottomLinePrice  Float
  bottomLineProfit Float
  targetPrice      Float
  targetProfit     Float

  outsourceItems ProjectOutsourceItem[]      @relation("ProjectPricingStrategyOutsourceItems")
  costItems       ProjectPricingStrategyCostItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model ProjectFinancialStructure {
  id String @id @default(uuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  estimationId String                @unique
  estimation   ProjectCostEstimation @relation(fields: [estimationId], references: [id], onDelete: Restrict)

  laborCost         Float
  rentCost          Float
  middleOfficeCost  Float
  executionCost     Float
  agencyFeeRate     Float?
  totalCost         Float

  outsourceItems      ProjectOutsourceItem[]                      @relation("ProjectFinancialStructureOutsourceItems")
  executionCostItems ProjectFinancialStructureExecutionCostItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model ProjectFinancialStructureExecutionCostItem {
  id String @id @default(uuid())

  financialStructureId String
  financialStructure   ProjectFinancialStructure @relation(fields: [financialStructureId], references: [id], onDelete: Cascade)

  costTypeOptionId String
  costTypeOption   SelectOption @relation("ProjectFinancialStructureExecutionCostType", fields: [costTypeOptionId], references: [id])

  budgetAmount Float
  remark       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([financialStructureId, costTypeOptionId])
  @@index([financialStructureId])
  @@index([costTypeOptionId])
}

model ProjectReimbursement {
  id String @id @default(uuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  applicantEmployeeId String
  applicantEmployee   Employee @relation("ProjectReimbursementApplicant", fields: [applicantEmployeeId], references: [id], onDelete: Restrict)

  occurredAt DateTime

  categoryOptionId String
  categoryOption   SelectOption @relation("ProjectReimbursementCategory", fields: [categoryOptionId], references: [id], onDelete: Restrict)

  amount Decimal

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([applicantEmployeeId])
  @@index([categoryOptionId])
  @@index([projectId, occurredAt])
}

model ProjectOutsourceItem {
  id String @id @default(uuid())

  type   String
  amount Int

  estimationId String?
  estimation   ProjectCostEstimation? @relation("ProjectCostEstimationOutsourceItems", fields: [estimationId], references: [id], onDelete: Cascade)

  pricingStrategyId String?
  pricingStrategy   ProjectPricingStrategy? @relation("ProjectPricingStrategyOutsourceItems", fields: [pricingStrategyId], references: [id], onDelete: Cascade)

  financialStructureId String?
  financialStructure   ProjectFinancialStructure? @relation("ProjectFinancialStructureOutsourceItems", fields: [financialStructureId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([estimationId])
  @@index([pricingStrategyId])
  @@index([financialStructureId])
}

model ProjectPricingStrategyCostItem {
  id String @id @default(uuid())

  strategyId String
  strategy   ProjectPricingStrategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  costTypeOptionId String
  costTypeOption   SelectOption @relation("ProjectPricingStrategyCostType", fields: [costTypeOptionId], references: [id])

  budgetAmount Float?
  remark       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([strategyId, costTypeOptionId])
  @@index([strategyId])
  @@index([costTypeOptionId])
}

model ProjectSegment {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  // 基础字段
  name           String
  statusOptionId String?
  statusOption   SelectOption? @relation("ProjectSegmentStatus", fields: [statusOptionId], references: [id])
  startDate      DateTime?
  endDate        DateTime?

  // relation

  // 所属项目
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // 环节负责人
  ownerId String?
  owner   Employee? @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  projectTasks ProjectTask[]

  @@index([projectId])
}

model ProjectTask {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  // 基础字段
  name           String
  statusOptionId String?
  statusOption   SelectOption? @relation("ProjectTaskStatus", fields: [statusOptionId], references: [id])
  dueDate        DateTime?

  // 所属环节
  segmentId String
  segment   ProjectSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  // 任务负责人
  ownerId String?
  owner   Employee? @relation("TaskOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  // 创建者
  creatorId String?
  creator   Employee? @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plannedWorkEntries PlannedWorkEntry[]

  @@index([segmentId])
  @@index([statusOptionId])
  @@index([ownerId])
}

model ProjectDocument {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  // 基础字段
  name         String
  typeOptionId String?
  typeOption   SelectOption? @relation("ProjectDocumentType", fields: [typeOptionId], references: [id])
  date         DateTime?
  isFinal      Boolean       @default(false)
  internalLink String? // 内部盘链接

  // 所属项目
  projectId   String
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestoneId String?
  milestone   ProjectMilestone? @relation("MilestoneDocuments", fields: [milestoneId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([milestoneId])
}

model Vendor {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  // 基础信息
  name     String
  fullName String?

  vendorTypeOptionId   String?
  vendorTypeOption     SelectOption? @relation("VendorVendorType", fields: [vendorTypeOptionId], references: [id])
  businessTypeOptionId String?
  businessTypeOption   SelectOption? @relation("VendorBusinessType", fields: [businessTypeOptionId], references: [id])
  location             String?

  // 联系方式
  contactName String?
  phone       String?
  email       String?
  wechat      String?

  // 能力描述
  strengths     String?
  notes         String?
  companyIntro  String?
  portfolioLink String?
  priceRange    String?

  // 风控
  isBlacklisted Boolean @default(false)

  // 合作状态
  cooperationStatusOptionId String?
  cooperationStatusOption   SelectOption? @relation("VendorCooperationStatus", fields: [cooperationStatusOptionId], references: [id])
  ratingOptionId            String?
  ratingOption              SelectOption? @relation("VendorRating", fields: [ratingOptionId], references: [id])
  lastCoopDate              String?
  cooperatedProjects        String?

  businessTypes VendorBusinessTypeOption[]
  services      VendorServiceOption[]

  // 项目多对多
  projects   Project[]          @relation("ProjectVendors")
  milestones ProjectMilestone[] @relation("MilestoneVendorParticipants")
  contracts  VendorContract[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VendorServiceOption {
  vendorId String
  optionId String

  vendor Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  option SelectOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@id([vendorId, optionId])
  @@index([optionId])
}

model VendorBusinessTypeOption {
  vendorId String
  optionId String

  vendor Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  option SelectOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@id([vendorId, optionId])
  @@index([optionId])
}

model ProjectMilestone {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  // 基础字段
  name           String
  typeOptionId   String?
  typeOption     SelectOption?          @relation("ProjectMilestoneType", fields: [typeOptionId], references: [id])
  startAt        DateTime?
  endAt          DateTime?
  datePrecision  MilestoneDatePrecision @default(DATE)
  location       String?
  methodOptionId String?
  methodOption   SelectOption?          @relation("ProjectMilestoneMethod", fields: [methodOptionId], references: [id])

  // 所属项目
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // 参与人员
  internalParticipants Employee[]      @relation("MilestoneInternalParticipants")
  vendorParticipants   Vendor[]        @relation("MilestoneVendorParticipants")
  clientParticipants   ClientContact[] @relation("MilestoneClientParticipants")

  // 关联资料
  documents ProjectDocument[] @relation("MilestoneDocuments")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model PlannedWorkEntry {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  taskId String
  task   ProjectTask @relation(fields: [taskId], references: [id])

  yearOptionId       String?
  yearOption         SelectOption? @relation("PlannedWorkEntryYear", fields: [yearOptionId], references: [id])
  weekNumberOptionId String?
  weekNumberOption   SelectOption? @relation("PlannedWorkEntryWeekNumber", fields: [weekNumberOptionId], references: [id])
  plannedDays        Float
  monday             Boolean       @default(false)
  tuesday            Boolean       @default(false)
  wednesday          Boolean       @default(false)
  thursday           Boolean       @default(false)
  friday             Boolean       @default(false)
  saturday           Boolean       @default(false)
  sunday             Boolean       @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActualWorkEntry {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  title String

  startDate DateTime
  endDate   DateTime

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([projectId])
  @@index([startDate])
}

model ApiCallLog {
  id String @id @default(uuid())

  path       String
  method     String
  statusCode Int

  requestBody  Json?
  responseBody Json?
  errorMessage String?

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  ip        String?
  userAgent String?

  durationMs Int?
  createdAt  DateTime @default(now())

  @@index([path, createdAt])
  @@index([method, createdAt])
  @@index([statusCode, createdAt])
  @@index([employeeId, createdAt])
}
