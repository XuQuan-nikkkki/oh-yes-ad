generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id        String   @id @default(uuid())
  name      String
  industry  String

  remark    String? 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts ClientContact[]
}

model ClientContact {
  id        String   @id @default(uuid())

  name      String
  title     String? 
  scope     String?
  preference String?

  phone     String?
  email     String?
  wechat    String?

  clientId  String
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}