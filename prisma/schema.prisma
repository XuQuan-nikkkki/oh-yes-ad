// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  name             String
  industryOptionId String
  industryOption   SelectOption @relation(fields: [industryOptionId], references: [id])
  remark           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts ClientContact[]
  projects Project[]
}

model SelectOption {
  id    String @id @default(uuid())
  field String
  value String
  color String?
  order Int?

  createdAt DateTime @default(now())

  clientsByIndustry Client[]

  @@unique([field, value])
  @@index([field, order])
}

model ClientContact {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  name       String
  title      String?
  scope      String?
  preference String?

  phone   String?
  email   String?
  wechat  String?
  address String?

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  milestones ProjectMilestone[] @relation("MilestoneClientParticipants")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LegalEntity {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  name      String  @unique
  fullName  String?
  taxNumber String?
  address   String?
  remark    String?
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bankAccounts BankAccount[]
  employees    Employee[]
}

model BankAccount {
  id String @id @default(uuid())

  legalEntityId String
  legalEntity   LegalEntity @relation(fields: [legalEntityId], references: [id])

  bankName      String
  bankBranch    String
  accountNumber String @unique

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  balanceSnapshots BankAccountBalanceSnapshot[]
}

model BankAccountBalanceSnapshot {
  id String @id @default(uuid())

  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  balance    Decimal
  recordedAt DateTime

  notionPageId String? @unique

  createdAt DateTime @default(now())

  @@index([bankAccountId, recordedAt])
}

model Employee {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  name String
  phone String? @unique
  fullName String?
  password String @default("admin123")

  function String?
  position String?
  level    String?

  departmentLevel1 String?
  departmentLevel2 String?

  employmentType   String?
  employmentStatus String @default("在职")

  entryDate DateTime?
  leaveDate DateTime?

  salary          Decimal?
  socialSecurity  Decimal?
  providentFund   Decimal?
  workstationCost Decimal?
  utilityCost     Decimal?

  bankAccountNumber String?
  bankName          String?
  bankBranch        String?

  legalEntityId String?
  legalEntity   LegalEntity? @relation(fields: [legalEntityId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leaveRecords    LeaveRecord[]
  ownedProjects   Project[]          @relation("ProjectOwner")
  projects        Project[]          @relation("ProjectMembers")
  projectSegments ProjectSegment[]
  ownedTasks      ProjectTask[]      @relation("TaskOwner")
  createdTasks    ProjectTask[]      @relation("TaskCreator")
  milestones      ProjectMilestone[] @relation("MilestoneInternalParticipants")
  actualWorkEntries ActualWorkEntry[]
  roles EmployeeRole[]
  apiCallLogs ApiCallLog[]
}

model Role {
  id        String @id @default(uuid())
  code      String @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees EmployeeRole[]
}

model EmployeeRole {
  employeeId String
  roleId     String
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  role     Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([employeeId, roleId])
  @@index([roleId])
}

model LeaveRecord {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  type      String // 以后可改 enum
  startDate DateTime
  endDate   DateTime

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId, startDate])
}

// 工作日变动：管理每年的休假、调休等日期变动
model WorkdayAdjustment {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  name       String? // 名称/描述，如「春节调休」
  changeType String  // 变动类型：上班、休假、调休
  startDate  DateTime // 开始日期
  endDate    DateTime // 结束日期

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startDate, endDate])
}

model Project {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  // 基础字段
  name   String
  type   String // CLIENT / INTERNAL（暂时字符串）
  status String?
  stage  String?

  startDate DateTime?
  endDate   DateTime?

  // relation

  // 所属客户
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  // 项目负责人
  ownerId String?
  owner   Employee? @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  // 项目成员（多对多）
  members Employee[] @relation("ProjectMembers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  segments ProjectSegment[]

  documents  ProjectDocument[]
  vendors    Vendor[]           @relation("ProjectVendors")
  milestones ProjectMilestone[]
  actualWorkEntries ActualWorkEntry[]
}

model ProjectSegment {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  // 基础字段
  name    String
  status  String?
  dueDate DateTime?

  // relation

  // 所属项目
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // 环节负责人
  ownerId String?
  owner   Employee? @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  projectTasks ProjectTask[]

  @@index([projectId])
}

model ProjectTask {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  // 基础字段
  name    String
  dueDate DateTime?

  // 所属环节
  segmentId String
  segment   ProjectSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  // 任务负责人
  ownerId String?
  owner   Employee? @relation("TaskOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  // 创建者
  creatorId String?
  creator   Employee? @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plannedWorkEntries PlannedWorkEntry[]

  @@index([segmentId])
  @@index([ownerId])
}

model ProjectDocument {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  // 基础字段
  name         String
  type         String? // 资料类型
  date         DateTime?
  isFinal      Boolean   @default(false)
  internalLink String? // 内部盘链接

  // 所属项目
  projectId  String
  project    Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestones ProjectMilestone[] @relation("MilestoneDocuments")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model Vendor {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  // 基础信息
  name     String
  fullName String?

  vendorType   String?
  businessType String?
  services     String[]
  location     String?

  // 联系方式
  contactName  String?
  phone        String?
  email        String?
  wechat       String?

  // 能力描述
  strengths     String?
  notes         String?
  companyIntro  String?
  portfolioLink String?
  priceRange    String?

  // 风控
  isBlacklisted Boolean @default(false)

  // 合作状态
  cooperationStatus String?
  rating            String?
  lastCoopDate      String?
  cooperatedProjects   String?

  // 项目多对多
  projects   Project[]          @relation("ProjectVendors")
  milestones ProjectMilestone[] @relation("MilestoneVendorParticipants")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectMilestone {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  // 基础字段
  name     String
  type     String?
  date     DateTime?
  location String?
  method   String?

  // 所属项目
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // 参与人员
  internalParticipants Employee[]      @relation("MilestoneInternalParticipants")
  vendorParticipants   Vendor[]        @relation("MilestoneVendorParticipants")
  clientParticipants   ClientContact[] @relation("MilestoneClientParticipants")

  // 关联资料
  documents ProjectDocument[] @relation("MilestoneDocuments")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model PlannedWorkEntry {
  id           String   @id @default(uuid())
  notionPageId String?  @unique

  taskId       String
  task         ProjectTask @relation(fields: [taskId], references: [id])

  year         Int
  weekNumber   Int
  plannedDays  Float
  monday       Boolean @default(false)
  tuesday      Boolean @default(false)
  wednesday    Boolean @default(false)
  thursday     Boolean @default(false)
  friday       Boolean @default(false)
  saturday     Boolean @default(false)
  sunday       Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActualWorkEntry {
  id            String   @id @default(uuid())
  notionPageId  String?  @unique

  title         String

  startDate     DateTime
  endDate       DateTime

  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id])

  projectId     String
  project       Project  @relation(fields: [projectId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([employeeId])
  @@index([projectId])
  @@index([startDate])
}

model ApiCallLog {
  id String @id @default(uuid())

  path       String
  method     String
  statusCode Int

  requestBody  Json?
  responseBody Json?
  errorMessage String?

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  ip        String?
  userAgent String?

  durationMs Int?
  createdAt  DateTime @default(now())

  @@index([path, createdAt])
  @@index([method, createdAt])
  @@index([statusCode, createdAt])
  @@index([employeeId, createdAt])
}
