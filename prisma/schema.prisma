// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  name     String
  industry String
  remark   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts ClientContact[]
  projects Project[]
}

model ClientContact {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  name       String
  title      String?
  scope      String?
  preference String?

  phone   String?
  email   String?
  wechat  String?
  address String?

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LegalEntity {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  name      String  @unique
  fullName  String?
  taxNumber String?
  address   String?
  remark    String?
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bankAccounts BankAccount[]
  employees    Employee[]
}

model BankAccount {
  id String @id @default(uuid())

  legalEntityId String
  legalEntity   LegalEntity @relation(fields: [legalEntityId], references: [id])

  bankName      String
  bankBranch    String
  accountNumber String @unique

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  balanceSnapshots BankAccountBalanceSnapshot[]
}

model BankAccountBalanceSnapshot {
  id String @id @default(uuid())

  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  balance    Decimal
  recordedAt DateTime

  notionPageId String? @unique

  createdAt DateTime @default(now())

  @@index([bankAccountId, recordedAt])
}

model Employee {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  name String

  function String?
  position String?
  level    String?

  departmentLevel1 String?
  departmentLevel2 String?

  employmentType   String
  employmentStatus String @default("在职")

  entryDate DateTime?
  leaveDate DateTime?

  salary          Decimal?
  socialSecurity  Decimal?
  providentFund   Decimal?
  workstationCost Decimal?
  utilityCost     Decimal?

  bankAccountNumber String?
  bankName          String?
  bankBranch        String?

  legalEntityId String?
  legalEntity   LegalEntity? @relation(fields: [legalEntityId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leaveRecords LeaveRecord[]
  ownedProjects Project[]  @relation("ProjectOwner")
  projects      Project[]  @relation("ProjectMembers")
}

model LeaveRecord {
  id           String  @id @default(uuid())
  notionPageId String? @unique

  type      String // 以后可改 enum
  startDate DateTime
  endDate   DateTime

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId, startDate])
}

model Project {
  id            String   @id @default(uuid())
  notionPageId  String?  @unique

  // 基础字段
  name          String
  type          String   // CLIENT / INTERNAL（暂时字符串）
  status        String?
  stage         String?

  startDate     DateTime?
  endDate       DateTime?

  // relation

  // 所属客户
  clientId      String?
  client        Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)

  // 项目负责人
  ownerId       String?
  owner         Employee? @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  // 项目成员（多对多）
  members       Employee[] @relation("ProjectMembers")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}